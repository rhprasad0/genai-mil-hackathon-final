# AO Radar — Terraform variables example
#
# Copy this file to `terraform.tfvars` (which is gitignored) and edit the
# values for your AWS account before `terraform plan`. Do not commit the
# resulting `terraform.tfvars`. Do not commit `terraform.tfstate`. Do not
# paste output that contains the DB master password JSON.
#
# Every value below is a placeholder. Replace with values from your account.

############################################################
# Core identity
############################################################

region      = "us-east-1"
name_prefix = "ao-radar"

############################################################
# Public DNS (placeholders only)
#
# Use the public Route 53 hosted zone the project owner has set aside for
# the demo. Pin by zone ID, not by zone name.
############################################################

domain_root    = "example.com"
hosted_zone_id = "Z_PUBLIC_HOSTED_ZONE_ID"
subdomain      = "hackathon"

############################################################
# Networking
############################################################

vpc_cidr = "10.42.0.0/16"
az_count = 2

############################################################
# RDS
############################################################

db_instance_class    = "db.t4g.micro"
db_allocated_storage = 20
db_engine_version    = "16.13"

############################################################
# Lambda
############################################################

lambda_runtime              = "python3.12"
lambda_memory_mb            = 512
lambda_timeout_s            = 25
mcp_reserved_concurrency    = 10
fraud_reserved_concurrency  = 5
db_ops_reserved_concurrency = 1

############################################################
# API Gateway
############################################################

api_throttle_rate  = 50
api_throttle_burst = 100

############################################################
# Logging
############################################################

log_retention_days = 7

############################################################
# Phase-gated VPC endpoints / route flags
#
# Phase 1: leave Secrets Manager / Lambda VPC endpoints and the SSE route
# off, but the MCP Lambda is still VPC-attached in this single committed
# module. Flip the flags below as you progress through the phases.
############################################################

enable_secretsmanager_vpce   = true
enable_lambda_vpce           = false
enable_s3_gateway_endpoint   = false
enable_logs_vpce             = false
disable_execute_api_endpoint = false
enable_sse_route             = false

############################################################
# Lambda zip artifact paths (relative to infra/)
#
# Application teammate populates `infra/build/*.zip`. Until those zips
# exist, run the placeholder zip recipe in `infra/build/PLACEHOLDER_README.md`
# so `terraform plan` can compute filebase64sha256().
############################################################

mcp_lambda_zip_path    = "./build/mcp.zip"
fraud_lambda_zip_path  = "./build/fraud.zip"
db_ops_lambda_zip_path = "./build/db_ops.zip"
